# Copy to application-local.yml (gitignored) for local overrides.
# Required env vars: JWT_SECRET, MINIO_URL, MINIO_ACCESS_KEY, MINIO_SECRET_KEY, OPENAI_API_KEY

spring:
  datasource:
    url: jdbc:postgresql://localhost:5433/recruitment_db
    username: postgres
    password: 123456
  flyway:
    enabled: true
    baseline-on-migrate: true
    baseline-version: 1
  jpa:
    hibernate:
      ddl-auto: update

jwt:
  secret: ${JWT_SECRET}
  expiration: 86400000
  refresh-expiration: 604800000

minio:
  url: ${MINIO_URL:http://localhost:9000}
  access-key: ${MINIO_ACCESS_KEY:minioadmin}
  secret-key: ${MINIO_SECRET_KEY:minioadmin}
  bucket: recruitment-cv

openai:
  api-key: ${OPENAI_API_KEY:}
