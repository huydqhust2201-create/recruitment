# ── BẮT BUỘC ──────────────────────────────────────────────────────
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Tạo chuỗi random bất kỳ, ít nhất 32 ký tự
# Ví dụ: openssl rand -base64 32
JWT_SECRET=change_this_to_a_very_long_random_secret_key_32chars

# ── TUỲ CHỌN (có giá trị mặc định) ───────────────────────────────
# Mật khẩu PostgreSQL nội bộ (mặc định: postgres)
DB_PASSWORD=postgres

# Gmail App Password để gửi email thông báo
# Lấy tại: https://myaccount.google.com/apppasswords
MAIL_USERNAME=
MAIL_PASSWORD=

# VNPay sandbox (mặc định đã là sandbox test, không cần thay)
VNPAY_TMN_CODE=CGPNBGEI
VNPAY_HASH_SECRET=RAOEXHYVSDDIIENYWSLDIIZTBEIYGHWT
